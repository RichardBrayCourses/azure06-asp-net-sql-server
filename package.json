{
  "name": "azure06-asp-net-sql-server",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "infra:deploy": "bash scripts/deploy-infra.sh",
    "infra:what-if": "bash scripts/what-if-infra.sh",
    "infra:destroy": "bash scripts/destroy-infra.sh",
    "shell:dev": "pnpm -C apps/shell run dev",
    "shell:env": "bash scripts/generate-shell-env.sh",
    "shell:build": "pnpm -C apps/shell run build",
    "shell:preview": "pnpm -C apps/shell run preview",
    "shell:upload": "bash scripts/upload-shell.sh",
    "shell:url": "bash scripts/show-url.sh",
    "backend:build": "dotnet build AllChecksOut.sln",
    "backend:test": "dotnet test AllChecksOut.sln",
    "database:source:reset": "bash scripts/reset-database-source.sh",
    "database:update:testing": "DEPLOY_ENV=testing bash scripts/update-database.sh",
    "database:update:staging": "DEPLOY_ENV=staging bash scripts/update-database.sh",
    "database:update:production": "DEPLOY_ENV=production bash scripts/update-database.sh",
    "database:reset:testing": "DEPLOY_ENV=testing bash scripts/reset-database.sh",
    "database:reset:staging": "DEPLOY_ENV=staging bash scripts/reset-database.sh",
    "database:reset:production": "DEPLOY_ENV=production bash scripts/reset-database.sh",
    "deploy-website": "pnpm run shell:env && pnpm run shell:build && pnpm run shell:upload",
    "deploy-everything": "pnpm run infra:deploy && pnpm run deploy-website && pnpm run shell:url",
    "deploy:testing": "DEPLOY_ENV=testing pnpm run deploy-everything",
    "deploy:staging": "DEPLOY_ENV=staging pnpm run deploy-everything",
    "deploy:production": "DEPLOY_ENV=production pnpm run deploy-everything",
    "get-storage-account:testing": "DEPLOY_ENV=testing bash scripts/show-url.sh --target-only",
    "get-storage-account:staging": "DEPLOY_ENV=staging bash scripts/show-url.sh --target-only",
    "get-storage-account:production": "DEPLOY_ENV=production bash scripts/show-url.sh --target-only",
    "connect-domain:testing": "DEPLOY_ENV=testing bash scripts/connect-custom-domain.sh",
    "connect-domain:staging": "DEPLOY_ENV=staging bash scripts/connect-custom-domain.sh",
    "connect-domain:production": "DEPLOY_ENV=production bash scripts/connect-custom-domain.sh",
    "whatif:testing": "DEPLOY_ENV=testing pnpm run infra:what-if",
    "whatif:staging": "DEPLOY_ENV=staging pnpm run infra:what-if",
    "whatif:production": "DEPLOY_ENV=production pnpm run infra:what-if",
    "destroy:testing": "DEPLOY_ENV=testing pnpm run infra:destroy",
    "destroy:staging": "DEPLOY_ENV=staging pnpm run infra:destroy",
    "destroy:production": "DEPLOY_ENV=production pnpm run infra:destroy",
    "release:testing": "bash scripts/release.sh testing",
    "release:staging": "bash scripts/release.sh staging",
    "release:production": "bash scripts/release.sh production",
    "wait-for-deploy:testing": "bash scripts/wait-for-deploy.sh testing",
    "wait-for-deploy:staging": "bash scripts/wait-for-deploy.sh staging",
    "wait-for-deploy:production": "bash scripts/wait-for-deploy.sh production",
    "repo:init": "bash scripts/repo-init.sh",
    "setup:github-azure": "bash scripts/setup-github-azure-credentials.sh",
    "type-check": "pnpm -r type-check",
    "package-cleanup": "pnpm -r package-cleanup && rm -rf node_modules"
  }
}
